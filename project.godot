; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GMTK_COUNTDOWN"
config/description="2D drag, platformer, top-down movement with per-level timer and save."
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SignalBus="*res://feature/core/autoload/signal_bus.gd"
SaveManager="*res://feature/core/autoload/save_manager.gd"
LevelTimer="*res://feature/core/autoload/level_timer.gd"
LevelManager="*res://feature/core/autoload/level_manager.gd"
HUD="*res://ui/hud.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="GMTK_COUNTDOWN"

